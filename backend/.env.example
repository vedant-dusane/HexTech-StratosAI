# StratosAI — Environment Configuration
# Team HexTech · Hackanova 5.0 · TCET
# Copy this file to .env — never commit .env to git

APP_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-string
DEBUG=true

# SQLite for local dev (zero setup)
DATABASE_URL=sqlite+aiosqlite:///./stratosai.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stratosai

# Anthropic Claude API — powers all 6 decision agents
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1200

# Comma-separated — no spaces, no quotes, no brackets
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
